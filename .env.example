VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# ----- Server-side ONLY (set via Supabase Dashboard → Edge Functions → Secrets) -----
# These are read by supabase/functions/sync-employee/index.ts. Never put them in
# this file in the deployed app — the .env files ship to the browser.
#
# Required (active dataset):
# DARWINBOX_BASE_URL="https://nwhrms.darwinbox.in"
# DARWINBOX_USERNAME="api_user@nxtwave.in"
# DARWINBOX_PASSWORD="..."
# DARWINBOX_API_KEY="..."
# DARWINBOX_DATASET_KEY="..."
#
# Optional (inactive dataset — used as fallback when employee not in active):
# DARWINBOX_API_KEY_INACTIVE="..."
# DARWINBOX_DATASET_KEY_INACTIVE="..."
#
# Optional tweaks (only if your Darwinbox tenant uses non-default endpoint/field):
# DARWINBOX_EMPLOYEE_PATH="/api/employee/search"
# DARWINBOX_SEARCH_FIELD="official_email_id"
# DARWINBOX_FORCE_REFRESH="0"
