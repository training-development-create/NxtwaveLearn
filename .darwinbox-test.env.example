# Local Darwinbox connectivity test secrets — used ONLY by scripts/test-darwinbox.mjs.
# Copy this file to ".darwinbox-test.env" (in the project root) and fill in the values.
# The .darwinbox-test.env file is gitignored automatically by the existing .env* rules.

DARWINBOX_BASE_URL=https://nwhrms.darwinbox.in
DARWINBOX_USERNAME=
DARWINBOX_PASSWORD=
DARWINBOX_API_KEY=
DARWINBOX_DATASET_KEY=

# Optional overrides if your tenant uses a non-default endpoint or search field:
# DARWINBOX_EMPLOYEE_PATH=/api/employee/search
# DARWINBOX_SEARCH_FIELD=official_email_id
